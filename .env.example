# Copy to .env and fill in your Supabase project values.
# Expo reads EXPO_PUBLIC_* vars at build time (safe to bundle in client).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge function secrets — NEVER put these here (they'd be bundled into the client app).
# Production:  supabase secrets set KEY=value
# Local dev:   create supabase/.env (git-ignored), then:
#              supabase functions serve --env-file ./supabase/.env
#
# Required:  REMOVE_BG_API_KEY=your-remove-bg-api-key
# Optional:  UPCITEMDB_KEY=your-upcitemdb-api-key
# Auto-set by Supabase runtime: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
